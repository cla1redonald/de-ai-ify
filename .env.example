# De-ai-ify — Environment Variables
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is in .gitignore.
#
# Both keys are SERVER-ONLY. Do not prefix with NEXT_PUBLIC_.
# Set in Vercel dashboard: Settings -> Environment Variables -> Production + Preview.

# Anthropic API key — used by POST /api/rewrite (Claude Sonnet)
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# Firecrawl API key — used by POST /api/scrape
# https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=
