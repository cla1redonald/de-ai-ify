# Anthropic API — powers the rewrite endpoint (POST /api/rewrite)
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
# Get from https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# Firecrawl API — powers URL scraping (POST /api/scrape)
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
# Get from https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=${FIRECRAWL_API_KEY}
